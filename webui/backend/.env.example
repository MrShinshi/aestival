# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-domain.com/api/ui/auth/github/callback

# Allowed GitHub usernames (comma-separated)
ALLOWED_USERS=Shinshi

# JWT secret — must match management_api.jwt_secret in bot_config.json
JWT_SECRET=change-me-to-a-random-string

# Bot paths (on the server)
BOT_API_URL=http://127.0.0.1:9090
BOT_LOG_PATH=/home/shinshi/aestival/bin/bot.log
BOT_CONTEXTS_BASE=/home/shinshi/aestival/bin/contexts

# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-me-to-another-random-string
